//============================================================================
//	include
//============================================================================
#include "FullscreenCopy.hlsli"

//============================================================================
//	resources
//============================================================================
Texture2D<float4> gTexture : register(t0);
SamplerState gSampler : register(s0);

//============================================================================
//	main
//============================================================================
float4 main(VSOutput input) : SV_TARGET0 {

	float4 output;

	output = gTexture.Sample(gSampler, input.texcoord);
	output.a = 1.0f;
	return output;
}
