//============================================================================
//	include
//============================================================================
#include "analyticGrid.hlsli"

//============================================================================
//	constants
//============================================================================
static const uint kNumVertex = 3;
static const float4 kPositions[kNumVertex] = {
	{ -1.0f, 1.0f, 0.0f, 1.0f },
	{ 3.0f, 1.0f, 0.0f, 1.0f },
	{ -1.0f, -3.0f, 0.0f, 1.0f }
};

//============================================================================
//	main
//============================================================================
VSOutput main(uint vertexID : SV_VertexID) {

	VSOutput output;

	// フルスクリーン三角形の頂点位置
	output.position = kPositions[vertexID];

	return output;
}
